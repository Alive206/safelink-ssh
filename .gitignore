# --- Go build artifacts ---
# Compiled binaries (Windows + cross-compiled outputs).
*.exe
*.exe~
*.dll
*.so
*.dylib
sshtunneld
sshtunneld.exe
/keyscan
/keyscan.exe

# Go test / coverage output.
*.test
*.out
coverage.txt
coverage.html

# --- Daemon runtime state ---
# Generated by `start.cmd` and Start-Process redirects.
runtime.pid
runtime.out.log
runtime.err.log
sshtunneld.out.log
sshtunneld.err.log
*.log

# Auto-generated on first launch — contains the bcrypt hash and the
# plaintext admin password.  Must NEVER be committed.
admin_credentials.txt
configs/admin_credentials.txt

# Persisted tunnel state (rewritten by the daemon at runtime).
configs/tunnels.json

# Uploaded SSH private keys live here (0600).  Never commit secrets.
configs/keys/
**/keys/*.pem
**/keys/*.key
**/keys/id_*
**/keys/*_rsa
**/keys/*_ed25519
**/keys/*_ecdsa

# Local-only smoke / scratch configs.
.demo_tmp/
*.local.yaml
*.local.yml

# --- Frontend (web/) ---
# Vite/Node artifacts.
web/node_modules/
web/dist/
web/.vite/
web/*.log
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*

# TypeScript incremental build cache.
web/tsconfig.tsbuildinfo
web/**/*.tsbuildinfo

# Embedded build output (regenerated by `npm run build`).
# Note: keep `internal/web/dist/` itself tracked because `//go:embed dist`
# requires the directory to exist for `go build`.  We ignore the hashed
# bundle output and the live index.html, but retain a placeholder so a
# fresh checkout still compiles.
internal/web/dist/assets/
internal/web/dist/index.html
!internal/web/dist/.gitkeep

# --- Editor / OS junk ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Misc ---
# Local environment overrides.
.env
.env.*
!.env.example
