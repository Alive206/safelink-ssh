# --- Go build artifacts ---
# Compiled binaries.
*.exe
*.exe~
*.dll
*.so
*.dylib
/server/safelink-server
/client/build/bin/

# Go test / coverage output.
*.test
*.out
coverage.txt
coverage.html

# --- Runtime state ---
# Generated at runtime.
runtime.pid
*.log

# Auto-generated on first launch — contains the bcrypt hash and the
# plaintext admin password.  Must NEVER be committed.
admin_credentials.txt
configs/admin_credentials.txt

# Persisted tunnel state (rewritten by the daemon at runtime).
configs/tunnels.json

# Uploaded SSH private keys live here (0600).  Never commit secrets.
configs/keys/
**/keys/*.pem
**/keys/*.key
**/keys/id_*
**/keys/*_rsa
**/keys/*_ed25519
**/keys/*_ecdsa

# Local-only smoke / scratch configs.
.demo_tmp/
*.local.yaml
*.local.yml

# --- Frontend ---
# Vite/Node artifacts.
**/node_modules/
**/dist/assets/
**/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript incremental build cache.
**/*.tsbuildinfo

# Embedded build output (regenerated by `npm run build`).
# Keep placeholder so `//go:embed dist` works on fresh checkout.
server/internal/web/dist/index.html
!server/internal/web/dist/.gitkeep
client/frontend/dist/index.html
!client/frontend/dist/.gitkeep

# --- Editor / OS junk ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Misc ---
# Local environment overrides.
.env
.env.*
!.env.example
