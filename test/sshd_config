# Test sshd config for sshtunneld end-to-end verification.
# Mounted into the linuxserver/openssh-server container as /config/sshd/sshd_config.

Port 2222
Protocol 2
PermitRootLogin no
PasswordAuthentication yes
PubkeyAuthentication yes
ChallengeResponseAuthentication no
UsePAM no

# Required for `mode: remote` to bind 0.0.0.0 inside the container.
GatewayPorts yes

AllowTcpForwarding yes
AllowAgentForwarding no
X11Forwarding no
PrintMotd no
ClientAliveInterval 60
ClientAliveCountMax 3
Subsystem sftp /usr/lib/ssh/sftp-server
